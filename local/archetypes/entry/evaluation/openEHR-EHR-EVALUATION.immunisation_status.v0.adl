	openEHR-EHR-EVALUATION.immunisation_status.v0

concept
	[at0000]	-- Immunisation status
language
	original_language = <[ISO_639-1::en]>
description
	original_author = <
		["name"] = <"Tara Bonet, Ana Pascual, Clara Calleja, Laura Moral, Martin Koch, David Hernández, Hugo Briceño, David Alonso,  Lluis Valle">
		["organisation"] = <"Modelatge del Coneixement Clínic Catsalut ">
		["email"] = <"ckm.salut@gencat.cat">
		["date"] = <"2026-03-03">
	>
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the patient’s immunization status in relation to a specific disease.">
			use = <"To record the patient’s immunization status in relation to a specific disease.
">
			keywords = <"immunization, status, patient record", ...>
			misuse = <"Not to record patient vaccinations, only verified immunizations.">
