definition
	CLUSTER[at0000] matches {    -- Spirometry test additional information
		items cardinality matches {1..*; unordered} matches {
			CLUSTER[at0002] occurrences matches {0..*} matches {    -- Measure name
				items cardinality matches {1..*; unordered} matches {
					ELEMENT[at0003] occurrences matches {0..1} matches {    -- Result
						value matches {
							DV_QUANTITY matches {*}
						}
					}
					ELEMENT[at0022] occurrences matches {0..1} matches {    -- Predicted result
						value matches {
							DV_QUANTITY matches {*}
						}
					}
					ELEMENT[at0024] occurrences matches {0..1} matches {    -- Measured/predicted ratio
						value matches {
							DV_PROPORTION matches {*}
						}
					}
				}
				name matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0004,    -- PEFT
							at0005,    -- EOTV
							at0006,    -- T0
							at0007,    -- BEV
							at0008,    -- VTCL
							at0009,    -- FVCL
							at0029,    -- FVC
							at0030]    -- FEV1
						}
					}
				}
			}
			CLUSTER[at0010] occurrences matches {0..1} matches {    -- Maneuver information
				items cardinality matches {1..*; unordered} matches {
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Maneuver number
						value matches {
							1|[local::at0012],
							2|[local::at0013],
							3|[local::at0014],
							4|[local::at0015],
							5|[local::at0016],
							6|[local::at0017],
							7|[local::at0018],
							8|[local::at0019]
						}
					}
					ELEMENT[at0020] occurrences matches {0..1} matches {    -- Quality of maneuver
						value matches {
							DV_CODED_TEXT matches {*}
						}
					}
					ELEMENT[at0021] occurrences matches {0..1} matches {    -- Sampling frequency
						value matches {
							C_DV_QUANTITY <
								property = <[openehr::382]>
								list = <
									["1"] = <
										units = <"Hz">
									>
								>
							>
						}
					}
					ELEMENT[at0026] occurrences matches {0..1} matches {    -- Total number of basal maneuvers
						value matches {
							DV_COUNT matches {*}
							DV_QUANTITY matches {*}
						}
					}
					ELEMENT[at0027] occurrences matches {0..1} matches {    -- Total number of postbronchodilator maneuvers
						value matches {
							DV_QUANTITY matches {*}
							DV_COUNT matches {*}
						}
					}
					ELEMENT[at0028] occurrences matches {0..1} matches {    -- Total number of maneuvers
						value matches {
							DV_COUNT matches {*}
						}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Spirometry test additional information">
					description = <"Additional parameters associated with spirometry testing, including metrics obtained as well as information describing maneuver execution and quality. ">
				>
				["at0002"] = <
					text = <"Measure name">
					description = <"Logical grouping of individual derived spirometric parameters. Each instance represents a specific measurement extracted from the spirometry maneuver (e.g., PEFT, BEV, T0), including its quantitative value, predicted reference, and normalized ratio.">
				>
				["at0003"] = <
					text = <"Result">
					description = <"Quantitative result of the specific spirometric parameter, expressed in appropriate physical units (e.g., liters, seconds, liters/second).">
				>
				["at0004"] = <
					text = <"PEFT">
					description = <"Time to peak expiratory flow.">
				>
				["at0005"] = <
					text = <"EOTV">
					description = <"End of test volume.">
				>
				["at0006"] = <
					text = <"T0">
					description = <"Tzero or back-extrapolated time.">
				>
				["at0007"] = <
					text = <"BEV">
					description = <"Back-extrapolated volume.">
				>
				["at0008"] = <
					text = <"VTCL">
					description = <"Volume-time curve length.">
				>
				["at0009"] = <
					text = <"FVCL">
					description = <"Flow-volume curve length.">
				>
				["at0010"] = <
					text = <"Maneuver information">
					description = <"This cluster supports detailed evaluation of test performance and enables traceability of individual maneuvers.">
				>
				["at0011"] = <
					text = <"Maneuver number">
					description = <"Sequential identifier assigned to each spirometry maneuver within a testing session.">
				>
				["at0012"] = <
					text = <"1">
					description = <"">
				>
				["at0013"] = <
					text = <"2">
					description = <"">
				>
				["at0014"] = <
					text = <"3">
					description = <"">
				>
				["at0015"] = <
					text = <"4">
					description = <"">
				>
				["at0016"] = <
					text = <"5">
					description = <"">
				>
				["at0017"] = <
					text = <"6">
					description = <"">
				>
				["at0018"] = <
					text = <"7">
					description = <"">
				>
				["at0019"] = <
					text = <"8">
					description = <"">
				>
				["at0020"] = <
					text = <"Quality of maneuver">
					description = <"Qualitative assessment of maneuver acceptability and technical quality based on standardized criteria (e.g., ATS/ERS grading systems). ">
				>
				["at0021"] = <
					text = <"Sampling frequency">
					description = <"Frequency at which spirometry signals (flow and volume) are digitally acquired, typically expressed in Hertz (Hz). ">
				>
				["at0022"] = <
					text = <"Predicted result">
					description = <"Reference (predicted) value derived from validated equations (e.g., GLI), adjusted for age, sex, height, and ethnicity where applicable. This value provides the expected normal measurement against which the observed result is compared for clinical interpretation.">
				>
				["at0024"] = <
					text = <"Measured/predicted ratio">
					description = <"Normalized ratio expressing the relationship between the measured value and its predicted reference (typically expressed as a percentage).">
				>
				["at0026"] = <
					text = <"Total number of basal maneuvers">
					description = <"Total number of spirometry maneuvers performed under baseline (pre-bronchodilator) conditions during the testing session. This value is used to assess adherence to minimum repeatability requirements.">
				>
				["at0027"] = <
					text = <"Total number of postbronchodilator maneuvers">
					description = <"Total number of spirometry maneuvers performed after administration of a bronchodilator. These measurements are used to assess bronchodilator responsiveness and reversibility of airflow limitation.">
				>
				["at0028"] = <
					text = <"Total number of maneuvers">
					description = <"Total number of spirometry maneuvers performed during the entire test session, including baseline and post-bronchodilator attempts.">
				>
				["at0029"] = <
					text = <"FVC">
					description = <"Forced vital capacity. The total volume of air that can be forcibly exhaled after full inspiration.">
				>
				["at0030"] = <
					text = <"FEV1">
					description = <"Forced expiratory volume in one second. The volume of air exhaled during the first second of the FVC maneuver.">
				>
			>
		>
		["ca"] = <
			items = <
				["at0000"] = <
					text = <"Informació addicional de la prova d’espirometria">
					description = <"Paràmetres addicionals associats a la prova d’espirometria, incloent els resultats obtinguts així com la informació rellevant sobre l’execució i la qualitat de les maniobres.">
				>
				["at0002"] = <
					text = <"Nom de la mesura">
					description = <"Agrupació paràmetres  relacionats amb la espirometria. Cada instància representa una mesura específica extreta de la maniobra d’espirometria (p. ex., PEFT, BEV, T0), incloent el seu valor quantitatiu, el valor de referència predit i el seu valor normalitzat.">
				>
				["at0003"] = <
					text = <"Resultat">
					description = <"Resultat quantitatiu del paràmetre espiromètric específic, expressat en les unitats físiques corresponents (p. ex., litres, segons, litres/segon).">
				>
				["at0004"] = <
					text = <"*PEFT (en)">
					description = <"*Time to peak expiratory flow. (en)">
				>
				["at0005"] = <
					text = <"*EOTV (en)">
					description = <"*End of test volume. (en)">
				>
				["at0006"] = <
					text = <"*T0 (en)">
					description = <"*Tzero or back-extrapolated time. (en)">
				>
				["at0007"] = <
					text = <"*BEV (en)">
					description = <"*Back-extrapolated volume. (en)">
				>
				["at0008"] = <
					text = <"*VTCL (en)">
					description = <"*Volume-time curve length. (en)">
				>
				["at0009"] = <
					text = <"*FVCL (en)">
					description = <"*Flow-volume curve length. (en)">
				>
				["at0010"] = <
					text = <"Informació de maniobra">
					description = <"Aquest clúster permet una avaluació detallada del rendiment de la prova i facilita la traçabilitat de les maniobres individuals.">
				>
				["at0011"] = <
					text = <"Número de maniobra">
					description = <"Identificador seqüencial assignat a cada maniobra dins d’una sessió d’espirometria. Permet diferenciar, ordenar i traçar les maniobres individuals.
">
				>
				["at0012"] = <
					text = <"*1 (en)">
					description = <"">
				>
				["at0013"] = <
					text = <"*2 (en)">
					description = <"">
				>
				["at0014"] = <
					text = <"*3 (en)">
					description = <"">
				>
				["at0015"] = <
					text = <"*4 (en)">
					description = <"">
				>
				["at0016"] = <
					text = <"*5 (en)">
					description = <"">
				>
				["at0017"] = <
					text = <"*6 (en)">
					description = <"">
				>
				["at0018"] = <
					text = <"*7 (en)">
					description = <"">
				>
				["at0019"] = <
					text = <"*8 (en)">
					description = <"">
				>
				["at0020"] = <
					text = <"Qualitat de la maniobra">
					description = <"Avaluació qualitativa de la maniobra basada en criteris estandarditzats (p.ex: ATS/ERS). ">
				>
				["at0021"] = <
					text = <"Freqüència de mostreig">
					description = <"Freqüència a la qual s’adquireixen digitalment les senyals de flux i volum, expressada en Hertz (Hz). ">
				>
				["at0022"] = <
					text = <"Valor predit">
					description = <"Valor de referència (predit) obtingut a partir d’equacions poblacionals validades (per exemple, GLI), ajustades per edat, sexe, alçada i ètnia quan correspon. Aquest valor representa la normalitat esperada amb la qual es compara el resultat observat per a la seva interpretació clínica.">
				>
				["at0024"] = <
					text = <"Relació valor mesurat/predit">
					description = <"Ratio que expressa la comparació entre el valor mesurat i el seu valor de referència predit (expressat com a percentatge).">
				>
				["at0026"] = <
					text = <"Número de maniobres basals">
					description = <"Nombre total de maniobres realitzades en condicions basals (pre-broncodilatador). S’utilitza per avaluar el compliment dels requisits mínims de repetibilitat.">
				>
				["at0027"] = <
					text = <"Número de maniobres post-broncodilatador">
					description = <"Nombre total de maniobres realitzades després de l’administració d’un broncodilatador. S’utilitzen per avaluar la resposta broncodilatadora i la reversibilitat.">
				>
				["at0028"] = <
					text = <"Número total de maniobres">
					description = <"Nombre total de maniobres realitzades durant tota la sessió, incloent basals i post-broncodilatador.">
				>
				["at0029"] = <
					text = <"*FVC (en)">
					description = <"*Forced vital capacity. The total volume of air that can be forcibly exhaled after full inspiration. (en)">
				>
				["at0030"] = <
					text = <"*FEV1 (en)">
					description = <"*Forced expiratory volume in one second. The volume of air exhaled during the first second of the FVC maneuver. (en)">
				>
			>
		>
		["es"] = <
			items = <
				["at0000"] = <
					text = <"Información adicional de la prueba de espirometría">
					description = <"Parámetros adicionales asociados a la prueba de espirometría, incluyendo los resultados obtenidos así como la información relevante sobre la ejecución y la calidad de las maniobras.">
				>
				["at0002"] = <
					text = <"Nombre de medida">
					description = <"Agrupación de parámetros relacionados con la espirometría. Cada instancia representa una medida específica extraída de la maniobra de espirometría (p. ej., PEFT, BEV, T0), incluyendo su valor cuantitativo, el valor de referencia predicho y su valor normalizado.">
				>
				["at0003"] = <
					text = <"Resultado">
					description = <"Resultado cuantitativo del parámetro espirométrico específico, expresado en las unidades físicas correspondientes (p. ej., litros, segundos, litros/segundo).">
				>
				["at0004"] = <
					text = <"*PEFT (en)">
					description = <"*Time to peak expiratory flow. (en)">
				>
				["at0005"] = <
					text = <"*EOTV (en)">
					description = <"*End of test volume. (en)">
				>
				["at0006"] = <
					text = <"*T0 (en)">
					description = <"*Tzero or back-extrapolated time. (en)">
				>
				["at0007"] = <
					text = <"*BEV (en)">
					description = <"*Back-extrapolated volume. (en)">
				>
				["at0008"] = <
					text = <"*VTCL (en)">
					description = <"*Volume-time curve length. (en)">
				>
				["at0009"] = <
					text = <"*FVCL (en)">
					description = <"*Flow-volume curve length. (en)">
				>
				["at0010"] = <
					text = <"Información de maniobra">
					description = <"Este clúster permite una evaluación detallada de la prueba y facilita la trazabilidad de las maniobras individuales.">
				>
				["at0011"] = <
					text = <"Número de maniobra">
					description = <"Identificador secuencial asignado a cada maniobra dentro de una sesión de espirometría. Permite diferenciar, ordenar y trazar las maniobras individuales.">
				>
				["at0012"] = <
					text = <"*1 (en)">
					description = <"">
				>
				["at0013"] = <
					text = <"*2 (en)">
					description = <"">
				>
				["at0014"] = <
					text = <"*3 (en)">
					description = <"">
				>
				["at0015"] = <
					text = <"*4 (en)">
					description = <"">
				>
				["at0016"] = <
					text = <"*5 (en)">
					description = <"">
				>
				["at0017"] = <
					text = <"*6 (en)">
					description = <"">
				>
				["at0018"] = <
					text = <"*7 (en)">
					description = <"">
				>
				["at0019"] = <
					text = <"*8 (en)">
					description = <"">
				>
				["at0020"] = <
					text = <"Calidad de la maniobra">
					description = <"Evaluación cualitativa de la aceptabilidad y calidad técnica de la maniobra basada en criterios estandarizados (por ejemplo, ATS/ERS). ">
				>
				["at0021"] = <
					text = <"Frecuencia de muestreo">
					description = <"Frecuencia a la que se adquieren digitalmente las señales de flujo y volumen, expresada en Hertz (Hz). ">
				>
				["at0022"] = <
					text = <"Valor predicho">
					description = <"Valor de referencia (predicho) obtenido a partir de ecuaciones poblacionales validadas (por ejemplo, GLI), ajustadas por edad, sexo, talla y etnia cuando corresponda. Este valor representa la normalidad esperada frente a la cual se compara el resultado observado para su interpretación clínica.">
				>
				["at0024"] = <
					text = <"Relación valor medido/predicho">
					description = <"Ratio que expresa la comparación entre el valor medido y su valor de referencia predicho (expresado como porcentaje).">
				>
				["at0026"] = <
					text = <"Número de maniobras basales">
					description = <"Número total de maniobras realizadas en condiciones basales (pre-broncodilatador) durante la sesión. Se utiliza para evaluar el cumplimiento de los requisitos mínimos de repetición.">
				>
				["at0027"] = <
					text = <"Número de maniobras post-broncodilatador">
					description = <"Número total de maniobras realizadas tras la administración de un broncodilatador. Se utilizan para evaluar la respuesta broncodilatadora y la reversibilidad de la limitación al flujo aéreo.">
				>
				["at0028"] = <
					text = <"Número total de maniobras">
					description = <"Número total de maniobras realizadas durante toda la sesión, incluyendo las basales y las posteriores al broncodilatador.">
				>
				["at0029"] = <
					text = <"*FVC (en)">
					description = <"*Forced vital capacity. The total volume of air that can be forcibly exhaled after full inspiration. (en)">
				>
				["at0030"] = <
					text = <"*FEV1 (en)">
					description = <"*Forced expiratory volume in one second. The volume of air exhaled during the first second of the FVC maneuver. (en)">
				>
			>
		>
	>
