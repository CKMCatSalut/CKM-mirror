description
	original_author = <
		["name"] = <"Modelatge del coneixement clínic - Catsalut">
		["organisation"] = <"Departament de Salut de la Generalitat de Catalunya">
		["email"] = <"ckm.salut@gencat.cat">
		["date"] = <"2023-09-22">
	>
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record additional spirometry parameters and maneuver quality indicators.">
			use = <"Used to capture detailed spirometry metrics, maneuver execution data and derived parameters.">
			keywords = <"Spirometry, pulmonary function test, maneuver quality.", ...>
			misuse = <"This archetype should not be used to other purpose than capture spirometry metrics, maneuver execution data and derived parameters.">
			copyright = <"© Departament de Salut de la Generalitat de Catalunya">
		>
		["ca"] = <
			language = <[ISO_639-1::ca]>
			purpose = <"Registrar paràmetres addicionals d’espirometria i indicadors de qualitat de les maniobres.">
			use = <"Peristir de manera detallada les mètriques d’espirometria, la informació sobre l’execució de les maniobres i els paràmetres derivats.">
			keywords = <"Espirometria, prova de funció pulmonar, funció respiratòria, qualitat de la maniobra, diagnòstic respiratori.", ...>
			misuse = <"Aquest arquetip no s’ha d’utilitzar per a cap altre propòsit que no sigui la recollida de mètriques d’espirometria, dades d’execució de les maniobres i paràmetres derivats.">
			copyright = <"© openEHR Foundation">
		>
		["es"] = <
			language = <[ISO_639-1::es]>
			purpose = <"Registrar parámetros adicionales de espirometría e indicadores de calidad de las maniobras.">
			use = <"Persistir de manera detallada las métricas de espirometría, la información sobre la ejecución de las maniobras y los parámetros derivados.">
			keywords = <"Espirometría, prueba de función pulmonar, función respiratoria, calidad de la maniobra, diagnóstico respiratorio.", ...>
			misuse = <"Este arquetipo no debe utilizarse para ningún otro propósito que no sea la recogida de métricas de espirometría, datos de ejecución de las maniobras y parámetros derivados.">
			copyright = <"© openEHR Foundation">
		>
	>
	lifecycle_state = <"in_development">
